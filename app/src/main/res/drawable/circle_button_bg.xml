<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFFFF"/>
            <stroke android:width="2dp" android:color="#FFE0E0E0"/>
